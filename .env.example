# General
APP_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/card_battles

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=replace_me_with_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_with_another_long_random_secret
JWT_ACCESS_EXPIRES_MINUTES=60
JWT_REFRESH_EXPIRES_DAYS=30

# Storage (MinIO for local dev, S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=card-battles-dev
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/card-battles-dev

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
