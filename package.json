{
  "name": "card-battles",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:api": "pnpm --filter @card-battles/api dev",
    "dev:web": "pnpm --filter @card-battles/web dev",
    "build": "pnpm -r run build",
    "test": "pnpm --filter @card-battles/api test",
    "typecheck": "pnpm --filter @card-battles/api tsc --noEmit && pnpm --filter @card-battles/web tsc --noEmit",
    "lint": "pnpm --filter @card-battles/web lint",
    "demo": "cd apps/api && PORT=3333 npx tsx src/combo-server.ts",
    "demo:tunnel": "npx localtunnel --port 3333",
    "db:migrate": "pnpm --filter @card-battles/api run db:migrate",
    "db:seed": "pnpm --filter @card-battles/api run db:seed",
    "db:generate": "pnpm --filter @card-battles/api run db:generate",
    "db:studio": "pnpm --filter @card-battles/api run db:studio"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
