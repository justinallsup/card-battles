{
  "name": "@card-battles/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "worker:dev": "tsx watch src/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:combo": "esbuild src/combo-server.ts --bundle --platform=node --outfile=dist/combo-server.js --external:@electric-sql/pglite --external:pg-native"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.556.0",
    "@aws-sdk/s3-request-presigner": "^3.556.0",
    "@card-battles/types": "workspace:*",
    "@electric-sql/pglite": "^0.3.15",
    "@hono/node-server": "^1.19.11",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.30.9",
    "hono": "^4.2.2",
    "ioredis": "^5.3.2",
    "ioredis-mock": "^8.13.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.21.2",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}